# Copy this file to .env.local and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# Hetzner VPS — the server running Openclaw
NEXT_PUBLIC_HETZNER_HOST=your-vps-ip-or-hostname

# Mac Mini browsing node
NEXT_PUBLIC_MAC_MINI_HOST=your-mac-mini-ip

# Openclaw base URL (if different from Hetzner)
NEXT_PUBLIC_OPENCLAW_URL=http://your-vps-ip:3000
